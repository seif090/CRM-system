{
  "name": "erp-crm-desktop",
  "version": "1.0.0",
  "description": "ERP & CRM Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5"
  },
  "build": {
