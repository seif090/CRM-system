<Window x:Class="ErpCrmDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ERP &amp; CRM System"
        Height="800" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#f0f0f0" Padding="4 2">
            <MenuItem Header="_File" Style="{StaticResource MenuStyle}">
                <MenuItem Header="_Reload" Click="Menu_Reload" InputGestureText="Ctrl+R"/>
                <Separator/>
                <MenuItem Header="_Exit" Click="Menu_Exit" InputGestureText="Alt+F4"/>
            </MenuItem>
            <MenuItem Header="_View" Style="{StaticResource MenuStyle}">
                <MenuItem Header="_Full Screen" Click="Menu_FullScreen" InputGestureText="F11"/>
                <MenuItem Header="Zoom _In" Click="Menu_ZoomIn" InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out" Click="Menu_ZoomOut" InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Reset Zoom" Click="Menu_ZoomReset" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="_Developer Tools" Click="Menu_DevTools" InputGestureText="F12"/>
            </MenuItem>
            <MenuItem Header="_Help" Style="{StaticResource MenuStyle}">
                <MenuItem Header="_Backend API Docs" Click="Menu_APIDocs"/>
                <Separator/>
                <MenuItem Header="_About" Click="Menu_About"/>
            </MenuItem>
        </Menu>

        <!-- Loading Overlay -->
        <Grid Grid.Row="1" x:Name="LoadingOverlay" Background="#f5f5f5" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="LoadingText" Text="Starting ERP &amp; CRM System..."
                           FontSize="18" Foreground="#666" HorizontalAlignment="Center"
                           FontFamily="Segoe UI"/>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Margin="0,16,0,0" Foreground="#1976d2"
                             Background="#e0e0e0"/>
            </StackPanel>
        </Grid>

        <!-- Error Overlay -->
        <Grid Grid.Row="1" x:Name="ErrorOverlay" Background="#f5f5f5" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="480">
                <TextBlock Text="&#x26A0;&#xFE0F; Cannot Connect"
                           FontSize="22" Foreground="#d32f2f" FontWeight="SemiBold"
                           HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                <TextBlock x:Name="ErrorDetail"
                           Text="The app could not reach the server."
                           FontSize="14" Foreground="#666" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Margin="0,12,0,0"
                           FontFamily="Segoe UI" TextAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="Retry" Click="Error_Retry"
                            Padding="20,8" FontSize="14" Background="#1976d2"
                            Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="WebView" Grid.Row="1" Visibility="Collapsed"/>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#1976d2" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready"
                           Foreground="White" FontSize="12" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="UrlText" Grid.Column="1" Text=""
                           Foreground="#b3d4fc" FontSize="11" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
